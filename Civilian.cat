            <profile name="SLM-9 Resupply Hauler" typeId="8a2d-efd5-4b60-f4fa" typeName="Ship" hidden="false" id="db7e-33b6-e5b3-cd57" publicationId="0486-c1f4-77a3-c714">
              <characteristics>
                <characteristic name="Thrust" typeId="d821-4294-3117-e8a6">9&quot;</characteristic>
                <characteristic name="Scan" typeId="960a-5d0e-18c5-4310">4&quot;</characteristic>
                <characteristic name="Sig" typeId="4feb-14c2-b1f1-9fa5">2&quot;</characteristic>
                <characteristic name="Hull" typeId="5253-be1d-917b-17d9">5</characteristic>
                <characteristic name="ES" typeId="42ae-03c9-d0ff-61da">3+</characteristic>
                <characteristic name="KS" typeId="a4d4-4c63-1848-24f8">5+</characteristic>
                <characteristic name="BS" typeId="05b6-9825-68e8-4983">6+</characteristic>
                <characteristic name="G" typeId="32ce-7bbb-1d0f-8c80">1</characteristic>
                <characteristic name="Special" typeId="fdf5-89b6-e62e-570f">Vectored, Resupply and Rearm, Flawed Design</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule name="Resupply and Rearm" id="f9aa-a29e-07e3-ccb6" hidden="false">
              <description>If this ship ends its movement in base contact with a friendly ship of Medium Tonnage or higher or a Space Station, pick one of the following:
Resupply: That Ship or Space Station recovers 3 Hull points and remove any Crippling Effect tokens.
Rearm: Increase the Limited-X value of any of that Ship or Space Station’s Weapons and Launch Assets by 1 until the end of the round.</description>
            </rule>
            <rule name="Flawed Design" id="eabd-32c2-f9a9-31bc" hidden="false">
              <description>This Ship cannot use its Resupply and Rearm rule if it is below half of its starting Hull.</description>
            </rule>
          </rules>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="8c7d-40bd-4b71-2488-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8c7d-40bd-4b71-2488-max" includeChildSelections="false"/>
          </constraints>
          <infoLinks>
            <infoLink name="Vectored" id="28d5-4b6f-9459-cfeb" hidden="false" type="rule" targetId="7a2f-fbe0-b3cd-98c8"/>
