                <characteristic name="G" typeId="32ce-7bbb-1d0f-8c80">1</characteristic>
                <characteristic name="Special" typeId="fdf5-89b6-e62e-570f">Porter F-2, Reinforced Armour, Monitor, Scrap Hauler, Scratch Bodge Job, Industrial Design</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule name="Scrap Hauler" id="83fd-5598-3e97-7fd7" hidden="false">
              <description>If this Group ends its activation within 1” of a Debris Field, this Group gains a scrap token and cannot gain scrap tokens from that Debris Field for the rest of the game. A Group can have a maximum of 8 scrap tokens at any one time. Any attached Payload ships that have any scrap tokens do not count towards this limit. Whenever another Ship within 6” of a friendly Ship with this rule is destroyed, pick one of those friendly Ships, that Ship gains a scrap token.</description>
            </rule>
            <rule name="Scratch Bodge Job" id="7f82-6c9f-9bae-3e18" hidden="false">
              <description>At the end of this Ship’s activation, you may remove any number of scrap tokens and choose one of the following:
Scrappy Plating: One friendly Ship within 6” recovers lost Hull points equal to the amount of scrap tokens removed.
Bodge Repairs: Remove a crippling effect from a friendly Ship within 6” for each scrap token removed.</description>
            </rule>
          </rules>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="99ab-d2e4-1ad0-d537-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="99ab-d2e4-1ad0-d537-max" includeChildSelections="false"/>
